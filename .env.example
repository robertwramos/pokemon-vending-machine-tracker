# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Application (client) ID from your Discord app
CLIENT_ID=your_application_client_id_here

# Guild ID for dev — commands register instantly on a single server
# Remove this (and use global deploy) for production
GUILD_ID=your_guild_id_here

# Prisma database provider (e.g. sqlite, postgresql, mysql)
DATABASE_PROVIDER=sqlite

# Prisma database connection URL
DATABASE_URL="file:./dev.db"
